# ── InsuranceAgent environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. Single-tenant demo: no auth / OAuth.

# LLM provider: `openai-compatible` (DeepSeek via Ollama Cloud) or `anthropic`.
LLM_PROVIDER=openai-compatible

# OpenAI-compatible (DeepSeek via Ollama Cloud). The model MUST support tool
# calling. On this path the model has no native PDF vision, so the extraction
# agent flattens PDFs to text first (lib/services/doc-parser.ts:pdfToText).
LLM_BASE_URL=https://ollama.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro:cloud
# Reasoning models spend budget on hidden reasoning before emitting the tool
# call — keep the ceiling high so structured output isn't truncated.
LLM_MAX_TOKENS=32000

# Anthropic (only used when LLM_PROVIDER=anthropic). Native PDF vision; a faster
# model for high-volume extraction.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5

# Supabase — Postgres (runs, events, human_actions, broker_outbox) + Storage.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Inngest — durable orchestrator + HITL waitForEvent.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Web research provider (Research agent). Optional — degrades gracefully.
TAVILY_API_KEY=

# Resend — onFailure ops alerts (optional).
RESEND_API_KEY=
OPS_ALERT_EMAIL=

# App base URL (falls back to Vercel/localhost).
APP_BASE_URL=http://localhost:3000
